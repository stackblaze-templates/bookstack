# ──────────────────────────────────────────────
# BookStack — environment variable reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Public URL BookStack is served from (no trailing slash)
APP_URL=http://localhost:6875

# ── Database credentials ───────────────────────
# These values must match on both the bookstack and db services.
DB_DATABASE=bookstack
DB_USERNAME=bookstack

# REQUIRED — choose a strong, unique password before starting
DB_PASSWORD=changeme_strong_password_here

# REQUIRED — strong root password for the MySQL container
MYSQL_ROOT_PASSWORD=changeme_root_password_here
